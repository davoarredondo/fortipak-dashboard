# Copia este archivo como ".env" (sin ".example") y completa con tus datos reales.
# El archivo ".env" nunca debe compartirse ni subirse a un repositorio.

# ---------------------------------------------------------------------------
# MODO DEMO
# ---------------------------------------------------------------------------
# Mientras esto esté en "true", la app usa datos de ejemplo y el login acepta
# cualquier usuario/contraseña. No requiere conexión real a SAP.
# Cuando ya tengas la conexión configurada abajo, cambia a "false".
DEMO_MODE=true

# ---------------------------------------------------------------------------
# AUTENTICACIÓN — SAP Business One Service Layer
# ---------------------------------------------------------------------------
# Se usa SOLO para validar usuario y contraseña contra SAP. La app no guarda
# contraseñas en ningún lado.
# URL típica: https://<servidor>:50000/b1s/v1  (puerto puede variar)
SAP_SERVICE_LAYER_URL=https://tu-servidor-sap:50000/b1s/v1
SAP_COMPANY_DB=SBO_FORTIPAK
# Si tu Service Layer usa un certificado autofirmado (común en redes internas),
# pon esto en "false". Idealmente, instala un certificado válido y déjalo en "true".
SAP_VERIFY_SSL=true

# ---------------------------------------------------------------------------
# DATOS — Conexión de SOLO LECTURA a SQL Server
# ---------------------------------------------------------------------------
# Crea un usuario de SQL Server dedicado a este dashboard, con permisos
# únicamente de SELECT (idealmente sobre vistas, no sobre las tablas directas).
# NO uses el usuario "sa" ni el usuario de SAP_SYSTEM.

# Caso A: una sola base de datos para las 3 sucursales (Multi-Sucursal de SAP B1
# activado dentro de una sola empresa). Llena solo este bloque "DEFAULT".
SQL_SERVER_DEFAULT=tu-servidor-sql,1433
SQL_DATABASE_DEFAULT=SBO_FORTIPAK
SQL_USER_DEFAULT=fortipak_dashboard_ro
SQL_PASSWORD_DEFAULT=

# Caso B: una base de datos distinta por sucursal. Si es tu caso, descomenta
# y llena estos 3 bloques (y puedes dejar vacío el bloque DEFAULT de arriba).
# SQL_SERVER_LEON=servidor-leon,1433
# SQL_DATABASE_LEON=SBO_FORTIPAK_LEON
# SQL_USER_LEON=fortipak_dashboard_ro
# SQL_PASSWORD_LEON=
#
# SQL_SERVER_AGS=servidor-ags,1433
# SQL_DATABASE_AGS=SBO_FORTIPAK_AGS
# SQL_USER_AGS=fortipak_dashboard_ro
# SQL_PASSWORD_AGS=
#
# SQL_SERVER_SLP=servidor-slp,1433
# SQL_DATABASE_SLP=SBO_FORTIPAK_SLP
# SQL_USER_SLP=fortipak_dashboard_ro
# SQL_PASSWORD_SLP=

# ---------------------------------------------------------------------------
# Intervalo de actualización automática del dashboard, en segundos
# ---------------------------------------------------------------------------
REFRESH_INTERVAL_SECONDS=60
